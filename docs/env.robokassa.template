# =============================================================================
# Шаблон переменных Robokassa — скопируйте блок ниже в КОРНЕВОЙ файл `.env`
# (рядом с docker-compose, не коммитить). Пароли возьмите в личном кабинете Robokassa.
# =============================================================================

# Включить интеграцию (false — кнопка оплаты и Result URL отключены)
ROBOKASSA_ENABLED=true

# Логин магазина в Robokassa (как в кабинете)
ROBOKASSA_MERCHANT_LOGIN=tenderyapp.ru

# Боевые пароли #1 и #2 (для подписи оплаты и проверки Result URL)
ROBOKASSA_PASSWORD_1=
ROBOKASSA_PASSWORD_2=

# Тестовые пароли #1 и #2 (из кабинета, раздел тестовых платежей)
ROBOKASSA_TEST_PASSWORD_1=
ROBOKASSA_TEST_PASSWORD_2=

# true — в ссылке IsTest=1 и используются TEST_PASSWORD_*; false — боевые пароли и реальные платежи
ROBOKASSA_USE_TEST_MODE=true

# Сейчас поддерживается только MD5
ROBOKASSA_HASH_ALGORITHM=MD5

# Подсказка для настройки кабинета; обработчик в приложении: POST /api/billing/robokassa/result
ROBOKASSA_RESULT_URL=https://tenderyapp.ru/api/billing/robokassa/result

# Куда вернёт браузер после оплаты / отказа (GET; источник истины — только Result URL)
ROBOKASSA_SUCCESS_URL=https://tenderyapp.ru/dashboard/billing/success
ROBOKASSA_FAIL_URL=https://tenderyapp.ru/dashboard/billing/fail

# Сумма тарифа «Стартер» в рублях (две цифры после точки в расчёте)
ROBOKASSA_STARTER_PRICE_RUB=3900.00

# Необязательно: только если Robokassa даст другой URL формы оплаты
# ROBOKASSA_PAYMENT_BASE_URL=https://auth.robokassa.ru/Merchant/Index.aspx
