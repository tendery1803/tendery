# Core
NODE_ENV=development

# Database
DATABASE_URL=postgresql://tendery:tendery@localhost:5432/tendery?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# S3 (dev via MinIO)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET_UPLOADS=tendery-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_FORCE_PATH_STYLE=true

# AI Gateway (external contour)
AI_GATEWAY_BASE_URL=http://localhost:4010
AI_GATEWAY_API_KEY=dev-ai-gateway-key-change-me

# OpenAI key (ONLY for ai-gateway service)
OPENAI_API_KEY=

