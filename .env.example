# =============================================================================
# Tendery — шаблон переменных окружения
# Скопируйте в .env и подставьте реальные значения. Файл .env не коммитить.
# Все токены, ключи и секреты хранить только в .env (не в коде и не в репозитории).
# =============================================================================

NODE_ENV=development

# -----------------------------------------------------------------------------
# База данных
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://tendery:tendery@localhost:5432/tendery?schema=public

# -----------------------------------------------------------------------------
# Redis (очереди, кэш)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# S3-совместимое хранилище (dev: MinIO)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET_UPLOADS=tendery-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_FORCE_PATH_STYLE=true

# MinIO (только для docker-compose, опционально)
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin123
# S3_BUCKET_UPLOADS=tendery-uploads

# -----------------------------------------------------------------------------
# AI Gateway (внешний контур; только URL и ключ доступа для продукта)
# -----------------------------------------------------------------------------
AI_GATEWAY_BASE_URL=http://localhost:4010
AI_GATEWAY_API_KEY=dev-ai-gateway-key-change-me

# -----------------------------------------------------------------------------
# OpenAI (только для apps/ai-gateway, не использовать в apps/web и apps/worker)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# Для apps/ai-gateway: порт сервера (по умолчанию 4010)
# PORT=4010

# -----------------------------------------------------------------------------
# Логирование (опционально)
# -----------------------------------------------------------------------------
# LOG_LEVEL=info
