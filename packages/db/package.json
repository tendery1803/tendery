{
  "name": "@tendery/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "prisma generate",
    "migrate:dev": "node ./scripts/with-root-env.mjs migrate dev",
    "migrate:deploy": "node ./scripts/with-root-env.mjs migrate deploy",
    "studio": "prisma studio",
    "typecheck": "tsc -p ./tsconfig.json --noEmit",
