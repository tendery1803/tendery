  },
  "devDependencies": {
    "@types/node": "^20",
    "argon2": "^0.44.0",
    "prisma": "^6.19.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@prisma/client": "^6.16.0"
  }
}
