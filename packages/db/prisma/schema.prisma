generator client {
  provider = "prisma-client-js"
  // В pnpm + Next (Turbopack) клиент в node_modules/.pnpm ломает require('.prisma/client/default').
  // Локальный output в пакете — стабильный путь для всех приложений.
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  emailVerifiedAt DateTime?
  isSystemAdmin Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     Session[]
  companyUsers CompanyUser[]
  tendersCreated Tender[]
  auditLogs    AuditLog[] @relation("AuditActor")
  passwordResetTokens PasswordResetToken[]
  backgroundJobs BackgroundJob[]
  aiRequestLogs AiRequestLog[]
  payments      Payment[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Company {
  id        String   @id @default(cuid())
  name      String
  inn       String?
  kpp       String?
  ogrn      String?
  /// Запрет внешних AI-вызовов для компании (основной контур остаётся локальным).
  aiExternalDisabled Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     CompanyUser[]
  documents CompanyDocument[]
  tenders   Tender[]
  subscription CompanySubscription?
  usageMonthly UsageMonthly[]
  profile   CompanyProfile?
  backgroundJobs BackgroundJob[]
  aiRequestLogs AiRequestLog[]
  payments      Payment[]
}

enum PaymentStatus {
  pending
  paid
  failed
}

/// Разовый платёж через Robokassa (InvId — номер счёта в шлюзе).
model Payment {
  id             String          @id @default(cuid())
  invId          Int             @unique @default(autoincrement())
  companyId      String
  userId         String
  planTarget     BillingPlanCode
  amountExpected Decimal         @db.Decimal(14, 2)
  status         PaymentStatus   @default(pending)
  /// Снимок: оплата создавалась в тестовом режиме Robokassa.
  testMode       Boolean         @default(false)
  paidAt         DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model CompanyProfile {
  id            String   @id @default(cuid())
  companyId     String   @unique
  legalAddress  String?  @db.Text
  postalAddress String?  @db.Text
  phone         String?
  email         String?
  contactPerson String?
  directorName  String?
  bankDetails   Json?
  extra         Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

enum BackgroundJobType {
  tender_file_registered
  tender_extract_text
  tender_parse
  tender_generate_draft
  tender_build_checklist
  tender_export
  knowledge_reindex
}

enum BackgroundJobStatus {
  pending
  queued
  processing
  done
  failed
  retry_scheduled
  canceled
}

model BackgroundJob {
  id          String              @id @default(cuid())
  type        BackgroundJobType
  status      BackgroundJobStatus @default(pending)
  companyId   String?
  userId      String?
  entityType  String?
  entityId    String?
  payload     Json?
  error       String?             @db.Text
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
  @@index([type, status])
  @@index([createdAt])
}

model AiRequestLog {
  id             String   @id @default(cuid())
  companyId      String?
  userId         String?
  operation      String
  sensitivity    String
  /// Не «промпт замаскирован»: для строки лога см. meta.maskedColumnSemantics / payloadWasMaskedBeforeSend (без миграции).
  masked         Boolean  @default(true)
  model          String?
  promptVersion  String?
  inputCharCount Int?
  outputTokensHint Int?
  validationOk   Boolean?
  meta           Json?
  createdAt      DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([createdAt])
  @@index([operation])
}

model KnowledgeMaterial {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  category  String?
  screenKey String?
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions KnowledgeMaterialVersion[]

  @@index([archived])
  @@index([category])
}

model KnowledgeMaterialVersion {
  id          String   @id @default(cuid())
  materialId  String
  version     Int
  body        String   @db.Text
  storageKey  String?
  contentType String?
  publishedAt DateTime @default(now())

  material KnowledgeMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([materialId, version])
  @@index([materialId])
}

enum CompanyRole {
  member
  admin
}

model CompanyUser {
  id        String      @id @default(cuid())
  companyId String
  userId    String
  role      CompanyRole @default(member)
  createdAt DateTime    @default(now())

  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
  @@index([companyId])
}

enum CompanyDocumentStatus {
  draft
  active
  expired
  archived
}

enum CompanyDocumentType {
  charter
  extract_egrul
  company_card
  power_of_attorney
  license
  certificate
  other
}

model CompanyDocument {
  id        String                @id @default(cuid())
  companyId String
  type      CompanyDocumentType
  title     String
  status    CompanyDocumentStatus @default(draft)
  expiresAt DateTime?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  company   Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  versions  CompanyDocumentVersion[]

  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, status])
}

model CompanyDocumentVersion {
  id          String         @id @default(cuid())
  documentId  String
  version     Int
  originalName String
  contentType String
  sizeBytes   Int
  storageKey  String
  uploadedAt  DateTime       @default(now())

  document    CompanyDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@index([documentId])
}

enum TenderSourceType {
  manual
  url
  file_upload
}

enum TenderStatus {
  draft
  active
  archived
}

enum TenderFileStatus {
  pending_upload
  stored
  registration_done
  failed
}

enum TenderFileExtractionStatus {
  none
  pending
  processing
  done
  failed
  skipped_unsupported
  quarantined
}

model Tender {
  id              String           @id @default(cuid())
  companyId       String
  title           String
  description     String?
  sourceType      TenderSourceType
  sourceUrl       String?
  status          TenderStatus     @default(draft)
  createdByUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator User?       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  files   TenderFile[]
  analyses TenderAnalysis[]
  draft    TenderDraft?
  checklistItems TenderChecklistItem[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, createdAt])
}

enum TenderAnalysisStatus {
  pending
  processing
  done
  failed
}

model TenderAnalysis {
  id        String               @id @default(cuid())
  tenderId  String
  status    TenderAnalysisStatus @default(pending)
  summary   String?              @db.Text
  model     String?
  error     String?                @db.Text
  rawOutput String?                @db.Text
  /** Товары/характеристики и блок услуг (JSON), опционально к верхним полям fields. */
  structuredBlock Json?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  tender Tender                @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  fields TenderAnalysisField[]

  @@index([tenderId])
  @@index([tenderId, status])
}

model TenderAnalysisField {
  id         String   @id @default(cuid())
  analysisId String
  fieldKey   String
  fieldLabel String
  valueText  String   @db.Text
  confidence Float
  sortOrder  Int      @default(0)

  analysis TenderAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
}

model TenderDraft {
  id        String   @id @default(cuid())
  tenderId  String   @unique
  body      String   @db.Text
  model     String?
  error     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)
}

model TenderChecklistItem {
  id        String   @id @default(cuid())
  tenderId  String
  itemKey   String
  title     String
  required  Boolean  @default(true)
  status    String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@unique([tenderId, itemKey])
  @@index([tenderId])
}

enum BillingPlanCode {
  demo
  starter
}

model CompanySubscription {
  id        String          @id @default(cuid())
  companyId String          @unique
  planCode  BillingPlanCode @default(demo)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model UsageMonthly {
  id             String   @id @default(cuid())
  companyId      String
  yearMonth      String
  /// Счётчик AI-операций по ТЗ (разбор, генерация черновика и т.д. — одна квота).
  aiOperationsCount Int   @default(0)
  aiAnalyzeCount Int      @default(0)
  draftGenCount  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, yearMonth])
  @@index([companyId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  targetType  String?
  targetId    String?
  meta        Json?
  createdAt   DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorUserId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TenderFile {
  id               String           @id @default(cuid())
  tenderId         String
  originalName     String
  contentType      String
  sizeBytes        Int
  storageKey       String
  fileStatus       TenderFileStatus @default(pending_upload)
  registrationNote String?
  extractionStatus TenderFileExtractionStatus @default(none)
  extractedText    String?        @db.Text
  extractionError  String?
  extractedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([tenderId])
  @@index([tenderId, extractionStatus])
}

